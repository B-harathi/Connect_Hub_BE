# ConnectHub - Environment Variables
# Copy this file to .env and fill in the values
# Used during CI/CD deployment to Elastic Beanstalk

# ======================
# SERVER CONFIGURATION
# ======================
PORT=5000
NODE_ENV=production
CLIENT_URL=https://your-cloudfront-url.cloudfront.net

# ======================
# DATABASE
# ======================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/connecthub

# ======================
# JWT AUTHENTICATION
# ======================
JWT_SECRET=your_secure_64_character_random_string
JWT_EXPIRE=7d

# ======================
# GOOGLE OAUTH
# ======================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ======================
# CLOUDINARY
# ======================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ======================
# RATE LIMITING
# ======================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ======================
# SECURITY
# ======================
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=your_session_secret

# ======================
# FILE UPLOAD LIMITS
# ======================
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ======================
# SOCKET.IO
# ======================
SOCKET_CORS_ORIGIN=https://your-cloudfront-url.cloudfront.net
